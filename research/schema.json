{
  "_schema": "crispwave.research.v1",
  "description": "Schema for research data generated by nightly tasks",

  "youtube_intel": {
    "description": "YouTube channel analysis",
    "structure": {
      "date": "YYYY-MM-DD",
      "channels_analyzed": ["channel1", "channel2"],
      "videos": [
        {
          "channel": "channel name",
          "title": "video title",
          "url": "https://youtube.com/watch?v=...",
          "published_date": "YYYY-MM-DD",
          "key_concepts": ["concept1", "concept2"],
          "summary": "2-3 sentence summary",
          "ideas": ["idea1", "idea2"],
          "relevance_score": 0.0
        }
      ],
      "trends_identified": ["trend1", "trend2"],
      "validation": {
        "videos_processed": 0,
        "ideas_extracted": 0,
        "checksum": "sha256_hash"
      }
    }
  },

  "market_intel": {
    "description": "Market research and trends",
    "structure": {
      "date": "YYYY-MM-DD",
      "sources": ["product-hunt", "hackernews", "github-trending"],
      "trending_topics": [
        {
          "topic": "topic name",
          "source": "source",
          "mentions": 0,
          "sentiment": "positive|neutral|negative",
          "description": "brief description"
        }
      ],
      "emerging_tools": [
        {
          "name": "tool name",
          "category": "category",
          "url": "https://...",
          "description": "brief desc",
          "stars": 0
        }
      ],
      "opportunities": ["opp1", "opp2"],
      "validation": {
        "data_points": 0,
        "checksum": "sha256_hash"
      }
    }
  },

  "competitive_intel": {
    "description": "Competitor and adjacent tool analysis",
    "structure": {
      "date": "YYYY-MM-DD",
      "competitors_analyzed": [
        {
          "name": "company name",
          "website": "https://...",
          "product_type": "category",
          "pricing": {
            "model": "subscription|one-time|freemium",
            "tiers": [
              {
                "name": "tier name",
                "price": "monthly price",
                "features": ["feature1", "feature2"]
              }
            ]
          },
          "positioning": "how they position themselves",
          "recent_news": "latest updates",
          "gaps_found": ["gap1", "gap2"]
        }
      ],
      "market_gaps": ["gap1", "gap2"],
      "validation": {
        "competitors_analyzed": 0,
        "checksum": "sha256_hash"
      }
    }
  },

  "synthesis": {
    "description": "Weekly consolidated research synthesis",
    "structure": {
      "week": "YYYY-WW",
      "start_date": "YYYY-MM-DD",
      "end_date": "YYYY-MM-DD",
      "top_trends": [
        {
          "theme": "trend theme",
          "evidence": ["evidence1", "evidence2"],
          "impact": "potential impact",
          "opportunities": ["opp1", "opp2"]
        }
      ],
      "emerging_opportunities": [
        {
          "idea": "idea description",
          "market_validation": "evidence of demand",
          "estimated_effort": "easy|medium|hard",
          "revenue_potential": "low|medium|high",
          "urgency": "low|medium|high"
        }
      ],
      "blog_topic_recommendations": [
        {
          "title": "proposed blog title",
          "angle": "what makes this interesting",
          "evidence": ["supporting evidence"],
          "estimated_reach": "predicted audience interest"
        }
      ],
      "validation": {
        "words": 0,
        "sections": 0,
        "checksum": "sha256_hash"
      }
    }
  },

  "validation_rules": {
    "required_fields": {
      "date": "All records must have YYYY-MM-DD date",
      "checksum": "All records must have SHA256 checksum",
      "summary": "All records must have human-readable summary"
    },
    "quality_checks": {
      "no_empty_fields": "All nested objects must have required fields",
      "no_placeholders": "No TODO, PLACEHOLDER, or undefined text",
      "min_length": "Descriptions must be >20 characters",
      "no_duplicates": "Records must be de-duplicated"
    }
  }
}
